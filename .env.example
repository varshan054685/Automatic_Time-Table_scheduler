# Copy this file to .env and fill in your values
# DO NOT commit .env — it is in .gitignore

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── App ───────────────────────────────────────
NODE_ENV=development

# Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_with_at_least_64_char_random_string

# ── CORS (production frontend URL) ───────────
CORS_ORIGIN=https://your-frontend.vercel.app

# ── Python solver microservice ────────────────
PYTHON_SERVICE_URL=http://127.0.0.1:8000

# ── Google OAuth (optional) ───────────────────
# Leave blank to disable the "Continue with Google" button
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Callback URL — must match what is registered in Google Cloud Console
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback

# ── Email / OTP ───────────────────────────────
# Option A: SendGrid
SENDGRID_API_KEY=SG.your_key_here
SENDGRID_FROM=noreply@yourdomain.com

# Option B: SMTP fallback (used if SendGrid key is not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Timetable Scheduler <your@gmail.com>"

# ── Production only ───────────────────────────
# URL of the deployed frontend (used for OAuth redirect after login)
FRONTEND_URL=https://your-frontend.vercel.app
