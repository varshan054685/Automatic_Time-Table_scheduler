# Database connection string (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Node environment: development | production
NODE_ENV=development

# Session secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Allowed CORS origins (comma-separated for multiple)
CORS_ORIGIN=https://your-frontend.vercel.app

# Python scheduler service URL (optional, defaults to http://127.0.0.1:8000)
# PYTHON_SERVICE_URL=http://127.0.0.1:8000
